{
  "name": "@byc/tipc",
  "type": "module",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "license": "ISC",
  "keywords": [],
  "exports": {
    ".": {
      "dev": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./preload": {
      "dev": "./src/preload.ts",
      "import": "./dist/preload.js",
      "require": "./dist/preload.cjs"
    },
    "./renderer": {
      "dev": "./src/renderer.ts",
      "import": "./dist/renderer.d.ts",
      "require": "./dist/renderer.d.ts"
    }
  },
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      ".": ["./dist/index.d.ts"],
      "preload": ["dist/preload.d.ts"],
      "renderer": ["dist/renderer.d.ts"]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "lint:fix": "npx nr lint --fix",
    "prepare": "husky || true",
    "play": "npx nr --filter ./playground dev"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.8.0",
    "@antfu/ni": "^0.23.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@swc/core": "^1.8.0",
    "@types/node": "^22.8.7",
    "electron": "^31.0.2",
    "eslint": "^9.14.0",
    "husky": "^9.1.6",
    "tsup": "^8.3.5",
    "vite": "^5.4.10"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
